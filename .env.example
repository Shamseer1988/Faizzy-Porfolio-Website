# ─── Database ───────────────────────────────────────────────────────────
# Local development uses a SQLite file (created by `npm run db:setup`).
# In production on Cloudflare, the D1 binding `DB` is used instead — this
# variable is ignored there. Leave it as-is for local dev.
DATABASE_URL="file:./prisma/dev.db"

# ─── Admin auth ─────────────────────────────────────────────────────────
# Secret used to sign admin session tokens. Generate one with:
#   openssl rand -base64 32
# In production set it as a Cloudflare secret: `wrangler secret put AUTH_SECRET`
AUTH_SECRET="change-me-to-a-long-random-string"

# Admin panel credentials (used at /admin/login). In production set these as
# Cloudflare secrets too: `wrangler secret put ADMIN_USERNAME` / ADMIN_PASSWORD
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="zohan2026"

# ─── Public URLs ────────────────────────────────────────────────────────
# Public site URL (SEO metadata / sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Cloudflare R2 (media storage) ──────────────────────────────────────
# Public base URL where the R2 bucket is served (a custom domain like
# https://media.faizzyworld.com, or the bucket's <id>.r2.dev subdomain).
# Uploaded files are stored as <R2_PUBLIC_URL>/uploads/<key>.
R2_PUBLIC_URL=""
# Hostname only (no protocol) — lets next/image optimise R2 images.
R2_PUBLIC_HOSTNAME=""
