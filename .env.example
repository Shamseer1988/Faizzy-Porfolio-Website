# PostgreSQL connection string. Leave unset to run the site with built-in
# default content (admin panel and contact form require a database).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zohan_portfolio"

# Secret used to sign admin session tokens. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Admin panel credentials (used at /admin/login)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="zohan2026"

# Public site URL (used for SEO metadata / sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
