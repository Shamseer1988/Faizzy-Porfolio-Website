{
  "name": "zohan-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:migrations": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > migrations/0001_init.sql",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv",
    "build:cf": "prisma generate && opennextjs-cloudflare build && node scripts/fix-wasm-paths.mjs",
    "preview": "npm run build:cf && opennextjs-cloudflare preview",
    "deploy": "npm run build:cf && wrangler deploy",
    "d1:setup:local": "wrangler d1 migrations apply faizzyworld-db --local && wrangler d1 execute faizzyworld-db --local --file=./prisma/seed-d1.sql",
    "d1:migrate:local": "wrangler d1 migrations apply faizzyworld-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply faizzyworld-db --remote",
    "d1:seed:remote": "wrangler d1 execute faizzyworld-db --remote --file=./prisma/seed-d1.sql",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lenis": "^1.3.25",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.111.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
